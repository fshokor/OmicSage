manifest {
    name            = 'OmicSage'
    author          = 'OmicSage Contributors'
    homePage        = 'https://github.com/fshokor/OmicSage'
    description     = 'AI-assisted modular single-cell multi-omics analysis platform'
    mainScript      = 'pipeline/main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.1.0-dev'
}

params {
    config   = "config/schema.yaml"
    outdir   = "results"
    modality = "scrna"
    help     = false
}

profiles {
    local {
        docker.enabled         = true
        docker.runOptions      = '--rm'
        singularity.enabled    = false
        process.executor       = 'local'
        process.cpus           = 4
        process.memory         = '16.GB'
    }
    docker {
        docker.enabled         = true
        docker.runOptions      = '--rm'
        singularity.enabled    = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }
    slurm {
        process.executor       = 'slurm'
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        process {
            withLabel: 'process_low' {
                cpus   = 2
                memory = '8.GB'
                time   = '1.h'
            }
            withLabel: 'process_medium' {
                cpus   = 8
                memory = '32.GB'
                time   = '6.h'
            }
            withLabel: 'process_high' {
                cpus   = 16
                memory = '64.GB'
                time   = '24.h'
            }
        }
    }
    ci {
        docker.enabled         = true
        process.executor       = 'local'
        process.cpus           = 2
        process.memory         = '6.GB'
    }
    test {
        params.config   = "tests/data/test_config.yaml"
        params.outdir   = "tests/results"
        params.modality = "scrna"
        docker.enabled  = true
        process.cpus    = 2
        process.memory  = '8.GB'
    }
}

process {
    errorStrategy = 'retry'
    maxRetries    = 2
    withLabel: 'process_python' {
        container = 'omicsage/python:latest'
    }
    withLabel: 'process_r' {
        container = 'omicsage/r:latest'
    }
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.svg"
}
